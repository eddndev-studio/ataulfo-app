<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon (API 26+): fondo oscuro de marca + mango dorado en la zona
     segura (~66dp de 108dp). API 23-25 cae a los ic_launcher.png por densidad
     (glifo sobre transparente). El monochrome alimenta los themed icons de
     API 33+ (el sistema lo tiñe; debe ser blanco puro sobre alpha). -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <monochrome android:drawable="@mipmap/ic_launcher_monochrome" />
</adaptive-icon>
